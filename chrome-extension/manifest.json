{
  "manifest_version": 3,
  "name": "Claude Usage Sync",
  "version": "1.1",
  "description": "claude.ai 사용량을 로컬 대시보드로 자동 동기화",
  "permissions": ["cookies"],
  "host_permissions": ["https://claude.ai/*", "http://localhost:*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
